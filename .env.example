## Flask
SECRET_KEY=changeme-use-a-random-secret-key
FLASK_ENV=development

## Database (SQLite for local, PostgreSQL for production)
DATABASE_URL=sqlite:///lovesta.db

## File uploads
UPLOAD_DIR=./storage/uploads
MAX_CONTENT_LENGTH=16777216

## Google OAuth
## Setup: https://console.cloud.google.com/ → APIs & Services → Credentials
## Authorized redirect URI (local):       http://localhost:5000/auth/google/callback
## Authorized redirect URI (production):  https://your-app.onrender.com/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
